{
  "name": "komdes-workspace",
  "private": true,
  "scripts": {
    "dev:komdes": "pnpm -F komdes dev",
    "build:komdes": "pnpm -F komdes build",
    "dev:docs": "pnpm -F docs dev",
    "build:docs": "pnpm -F docs build",
    "docs": "pnpm -F komdes docs",
    "validate": "pnpm format && pnpm lint:check && pnpm build:komdes && pnpm build:docs",
    "typecheck": "pnpm -F komdes typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:komdes && changeset publish",
    "format": "biome check --write",
    "format:check": "biome check",
    "lint:check": "biome lint .",
    "prepare": "husky",
    "changelog:mdx": "node scripts/generate-mdx-changelog.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-popover": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "latest",
    "fumadocs-ui": "latest",
    "lucide-react": "^1.11.0",
    "react": "latest",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
